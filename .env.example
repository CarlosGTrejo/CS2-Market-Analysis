# dlt resolves the following GCP credentials natively from gcloud cli or service account:
# - `client_email`
# - `private_key`
# - `project_id`

# Pulumi GCP provider resolves the following, which are set when using gcloud CLI or service account:
# - `GOOGLE_APPLICATION_CREDENTIALS`: Path to service account JSON key file
# - `GOOGLE_CREDENTIALS`: Actual JSON content of service account key
# - `GOOGLE_PROJECT`: GCP project ID

# No configuration needed for Prefect. `prefect cloud login` will securely 
# authenticate and save your credentials to `~/.prefect/profiles.toml`.
# The Pulumi script takes care of fetching these credentials and
# the Prefect SDK automatically resolves these credentials from the active profile.


# Specify the deployment stack to use (will be used to create stack-specific resources like GCS buckets and BigQuery datasets):
# If not set, it will default to "dev".
PULUMI_STACK=prod

# dbt doesn't resolve GCP project/region from gcloud cli or service account
# so these must be set. Note that we are using the environment variable that is natively resolved by the Pulumi GCP provider
# in case the user has multiple projects.
GOOGLE_PROJECT=your-gcp-project-id

# Prefered GCP region for resources. Use lowercase to avoid issues with Pulumi provisioning.
# Available regions: https://docs.cloud.google.com/storage/docs/locations#location-r
# if not set, it will default to "us-central1".
GOOGLE_REGION=us-central1

# Set the cloud scheduler region if needed, not all regions support cloud scheduler. You can list them with:
# gcloud scheduler locations list
# GOOGLE_CLOUD_SCHEDULER_REGION=us-central1

# Webshare.io proxy url to avoid IP blocking when extracting data from Steam's APIs.
# Set "Authentication Method" to "Username/Password"
# Set "Connection Method" to "Rotating Proxy Endpoint"
# Set "Proxy Protocol" to "HTTP"
PROXY_URL="xxxxxxxx-rotate:PASSWORD1234@p.webshare.io:80"

# Cloudflare credentials to deploy dashboard
# After creating a token here it'll show the token and account ID: https://dash.cloudflare.com/?to=/:account/api-tokens
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# (Optional) Prefect configuration for DLT task execution limits, task timeout is in seconds (default is 2 hours).
# Specifies retry logic for the heavy extract & load runs.
# PREFECT_TASK_RETRIES=3
# PREFECT_TASK_RETRY_DELAY=60
# PREFECT_TASK_TIMEOUT=7200

# (Optional) Deployment image tag for the Cloud Run container.
# Defaults to "rev-1" if omitted.
# IMAGE_TAG="rev-1"